// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-m cmd-p": "workspace::ToggleZoom",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-k cmd-c": ["editor::ToggleComments", { "advance_downwards": false }],
    },
  },
  {
    "context": "VimControl && (vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "bindings": {
      "] f": "vim::NextMethodStart",
      "[ f": "vim::PreviousMethodStart",
      "] c": "vim::NextComment",
      "[ c": "vim::PreviousComment",
      "] s": "editor::GoToNextSymbol",
      "[ s": "editor::GoToPreviousSymbol",
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",
      "] g": "editor::GoToHunk",
      "[ g": "editor::GoToPreviousHunk",
    },
  },
  {
    "context": "buffer_search_deployed > (VimControl && (vim_mode == helix_normal || vim_mode == helix_select))",
    "bindings": {
      "escape": "buffer_search::Dismiss",
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "bindings": {
      "g o": "editor::ToggleAllDiffHunks"
    }
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "bindings": {
      "g q": "vim::Rewrap"
    }
  }
]
